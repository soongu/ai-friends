# .env.example — 복사해서 .env 로 저장한 뒤 값을 채워 주세요.
# .env 파일은 .gitignore 되어 있어 커밋되지 않습니다.
#
# 사용법:
#   cp .env.example .env
#   # 이후 GEMINI_API_KEY 값을 실제 키로 교체
#
# 이 파일의 변수는 두 가지 경로로 사용됩니다.
#   1) docker-compose 가 .env 파일을 자동 로드 → 컨테이너 환경변수에 주입
#   2) IDE 로컬 실행 시 DotenvInitializer 가 .env 를 읽어 Spring Environment 로 주입

# ---------------------------------------------------------
# 활성 Spring 프로파일 (도커 실행 시 적용)
#   - 기본값: docker,gemini  (MySQL + Gemini 클라우드 모델)
#   - 로컬 Ollama 로 바꾸고 싶으면: docker,ollama
#   - 두 프로바이더를 모두 등록하고 spring.ai.model.chat 으로 스위칭하려면: docker,ollama,gemini
#
# IDE 로컬 실행에서는 application.yml 의 기본 프로파일 / IntelliJ Run Configuration 이 적용됨.
# ---------------------------------------------------------
SPRING_PROFILES_ACTIVE=docker,gemini

# ---------------------------------------------------------
# Google Gemini API (필수, AI 채팅용)
# https://aistudio.google.com/app/apikey
# ---------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# ---------------------------------------------------------
# OpenAI API (Day 9 — STT/TTS 용. Whisper + gpt-4o-mini-tts 호출)
# https://platform.openai.com/api-keys  (카드 등록 필수, 무료 크레딧 없음)
#
# 채팅용 GEMINI_API_KEY 와 분리된 키. application.yml 의 spring.ai.openai.audio.* 사브트리만
# 이 키를 쓰고, 채팅(spring.ai.openai.chat.*) 은 GEMINI_API_KEY 를 그대로 쓴다.
#
# 한 사이클(마이크→STT→ChatClient→TTS) 비용은 약 $0.0005 = 0.7원. 학생 실습용으로는
# 키만 발급받고 결제 한도를 $5~10 으로 잡아두면 충분.
# ---------------------------------------------------------
OPENAI_API_KEY=
# STT 모델: gpt-4o-transcribe (GPT-4o 기반 최신, 오늘 디폴트) / whisper-1 (레거시) /
#          gpt-4o-mini-transcribe (저단가) 중 택일. 빈 값이면 Spring AI 기본값(whisper-1).
OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# ---------------------------------------------------------
# TTS 프로바이더 selector (Day 9)
#   - openai      : 기본. gpt-4o-mini-tts 로 한국어 narrator 톤. 단가 저렴.
#   - elevenlabs  : 미연시·캐릭터 톤이 풍부. 한국어 억양은 voice 마다 운에 가까움.
# 코드 0줄 수정으로 백엔드가 갈린다 — Spring AI TextToSpeechModel 인터페이스 추상화 효과.
# DevTools Network 탭의 응답 헤더 X-TTS-Provider / X-TTS-Voice 또는 GET /api/voice/info 로
# 현재 활성 프로바이더 즉시 확인 가능.
# ---------------------------------------------------------
TTS_PROVIDER=openai

# ---------------------------------------------------------
# ElevenLabs API (선택, TTS_PROVIDER=elevenlabs 일 때만 필요)
# https://elevenlabs.io  (무료 티어 月 10,000 글자)
#
# voice-id 슬롯에 박는 식별자는 *이름이 아니라 UUID*. ElevenLabs 의 Voices 탭에서 prebuilt
# voice 의 UUID 를 복사해 VoiceSynthesisService 의 ELEVENLABS_VOICE_BY_MOOD 표에 매핑한다.
# ---------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
# 매핑 테이블 누락 시 폴백되는 default voice (Rachel — ElevenLabs prebuilt 영어/다국어 화자).
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ---------------------------------------------------------
# Groq API (선택, 무료 고속 추론용 — Day 1 과제 2)
# https://console.groq.com  (카드 등록 불필요)
# SPRING_PROFILES_ACTIVE=docker,groq 로 전환 시 사용
# ---------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------------
# OpenAI API (Day 7 이미지 생성 전용 — 진짜 OpenAI 엔드포인트, chat 의 Gemini 호환과 별개)
# https://platform.openai.com/api-keys
#
# AIFRIENDS_IMAGE_PROVIDER:
#   pollinations(기본): 무료, 학습용. OPENAI_API_KEY 비워둬도 됨.
#   openai: 유료, 품질 우선. OPENAI_API_KEY 필수.
# AIFRIENDS_IMAGE_MODEL_NAME: 비용 매핑 키 (ImageCostEstimator).
#   pollinations-flux | openai-dall-e-3-standard | openai-dall-e-3-hd
# ---------------------------------------------------------
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=hd
OPENAI_IMAGE_STYLE=vivid
AIFRIENDS_IMAGE_PROVIDER=openai
AIFRIENDS_IMAGE_MODEL_NAME=openai-dall-e-3-hd

# ---------------------------------------------------------
# Ollama (로컬 LLM 데몬) base-url
#   - Ollama 데몬은 호스트(노트북)에 설치되어 있다고 가정 (Mac Metal/GPU 가속 활용).
#   - 도커 컨테이너 안의 Spring 앱이 호스트의 Ollama 로 접속하려면 host.docker.internal 사용.
#   - IDE 로컬 실행 시에는 application.yml 의 기본값(http://localhost:11434)이 적용됨.
# ---------------------------------------------------------
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ---------------------------------------------------------
# 로컬(IDE) 실행용 DB URL (H2 인메모리 기본값)
# docker-compose 로 실행할 때는 이 값이 덮어씌워지므로 신경 쓰지 않아도 됩니다.
# ---------------------------------------------------------
DB_URL=jdbc:h2:mem:aifriends;DB_CLOSE_DELAY=-1

# ---------------------------------------------------------
# docker-compose 용 MySQL 설정
#   - 호스트에서 접속할 포트: 3309  (컨테이너 내부는 3306)
#   - 예) 로컬 DBeaver 로 접속 시: localhost:3309 / aifriends / aifriends1234
# ---------------------------------------------------------
MYSQL_ROOT_PASSWORD=root1234
MYSQL_DATABASE=aifriends
MYSQL_USER=aifriends
MYSQL_PASSWORD=aifriends1234
